---
import { Image } from "astro:assets";
import background from "../../logos/st2_background_2560x1440.png";
import logo from "../../logos/st2_logo_transparent_1280x720.png";
import { LINKS } from "../data/links";
import { SITE } from "../data/site";
import Icon from "./Icon.astro";
---

<section class="hero">
  <Image
    src={background}
    alt=""
    class="hero-bg"
    widths={[768, 1280, 1920, 2560]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
  />
  <div class="hero-scrim" aria-hidden="true"></div>

  <div class="wrap hero-content">
    <h1 class="hero-logo-wrap">
      <Image src={logo} alt="Sheep Tag 2" class="hero-logo" loading="eager" />
    </h1>
    <p class="hero-tagline">{SITE.tagline}</p>
    <p class="hero-subline">{SITE.heroSubline}</p>
    <div class="hero-ctas">
      <a class="btn btn--primary" href={LINKS.wishlist} target="_blank" rel="noopener">
        <Icon name="steam" size={18} /> Wishlist on Steam
      </a>
      <a
        class="btn btn--secondary"
        id="trailer-open"
        href={LINKS.trailer}
        target="_blank"
        rel="noopener"
      >
        <Icon name="play" size={18} /> Watch Trailer
      </a>
    </div>
  </div>

  <dialog id="trailer-dialog" class="theater" aria-label="Sheep Tag 2 official trailer">
    <button type="button" class="theater-close" id="trailer-close" aria-label="Close trailer">
      <Icon name="close" size={26} />
    </button>
    <div class="theater-frame" id="trailer-frame"></div>
  </dialog>
</section>

<style>
  .hero {
    position: relative;
    /* Pull the full-bleed art up behind the translucent sticky header. */
    margin-top: calc(-1 * var(--st-header-h));
    min-height: 100svh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 60% center;
    z-index: -2;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(
        to right,
        rgba(8, 10, 6, 0.85),
        rgba(8, 10, 6, 0.5) 38%,
        rgba(8, 10, 6, 0.12) 62%,
        transparent 80%
      ),
      linear-gradient(to top, rgba(8, 10, 6, 0.78), transparent 42%);
  }
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.1rem;
    padding-top: calc(var(--st-header-h) + 2vh);
    padding-bottom: 6vh;
    max-width: 680px;
  }
  .hero-logo-wrap {
    margin: 0;
    line-height: 0;
  }
  .hero-logo {
    width: clamp(240px, 46vw, 600px);
    height: auto;
    filter: drop-shadow(0 8px 22px rgba(0, 0, 0, 0.45));
    transform-origin: 50% 80%;
    will-change: transform;
  }
  .hero-tagline {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.3rem, 1rem + 1.8vw, 2.1rem);
    line-height: 1.15;
    color: var(--st-ink);
    text-wrap: balance; /* single line on desktop; even lines when narrow screens wrap it */
    /* All-around dark ring + downward depth keeps it legible even over the white sheep. */
    text-shadow:
      0 0 2px rgba(0, 0, 0, 0.95),
      0 0 5px rgba(0, 0, 0, 0.8),
      0 1px 2px rgba(0, 0, 0, 0.95),
      0 3px 16px rgba(0, 0, 0, 0.6);
  }
  .hero-subline {
    font-size: clamp(1rem, 0.95rem + 0.4vw, 1.2rem);
    color: var(--st-ink);
    max-width: 56ch;
    text-wrap: pretty;
    text-shadow:
      0 0 2px rgba(0, 0, 0, 0.9),
      0 0 4px rgba(0, 0, 0, 0.75),
      0 1px 2px rgba(0, 0, 0, 0.95),
      0 2px 10px rgba(0, 0, 0, 0.6);
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.4rem;
  }
  .hero-ctas .btn--secondary {
    background: rgba(10, 12, 8, 0.35);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }

  /* Animated logo — cartoon "breathing" tween (WEBSITE_PROPOSAL.md §6.3.1).
     The sway starts and ends at the intro's neutral end pose (scale 1, no tilt)
     so the handoff between the two animations is seamless. */
  @media (prefers-reduced-motion: no-preference) {
    .hero-logo {
      animation:
        hero-in 0.7s cubic-bezier(0.2, 0.9, 0.25, 1.2) both,
        hero-sway 11s ease-in-out 0.7s infinite;
    }
    @keyframes hero-in {
      from {
        opacity: 0;
        transform: scale(0.8);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }
    @keyframes hero-sway {
      0%,
      100% {
        transform: scale(1) rotate(0deg);
      }
      25% {
        transform: scale(1.03) rotate(2.5deg);
      }
      75% {
        transform: scale(0.975) rotate(-2.5deg);
      }
    }
  }

  @media (max-width: 640px) {
    .hero-content {
      max-width: 100%;
    }
    .hero-logo {
      width: min(78vw, 360px);
    }
    /* Gentler motion where there's less room */
    @media (prefers-reduced-motion: no-preference) {
      @keyframes hero-sway {
        0%,
        100% {
          transform: scale(1) rotate(0deg);
        }
        25% {
          transform: scale(1.02) rotate(1.5deg);
        }
        75% {
          transform: scale(0.985) rotate(-1.5deg);
        }
      }
    }
  }

  /* Trailer theater */
  .theater {
    width: min(1100px, 92vw);
    max-width: 92vw;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--st-ink);
    overflow: visible;
  }
  .theater::backdrop {
    background: rgba(6, 8, 5, 0.86);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
  }
  .theater-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    background: #000;
    border-radius: var(--st-radius);
    overflow: hidden;
    box-shadow: var(--st-shadow-lg);
  }
  .theater-frame :global(iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .theater-close {
    position: absolute;
    top: -46px;
    right: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    cursor: pointer;
  }
  .theater-close:hover {
    background: rgba(255, 255, 255, 0.24);
  }
</style>

<script>
  const openLink = document.getElementById("trailer-open") as HTMLAnchorElement | null;
  const dialog = document.getElementById("trailer-dialog") as HTMLDialogElement | null;
  const frame = document.getElementById("trailer-frame");
  const closeBtn = document.getElementById("trailer-close");
  const videoId = "JxZhfs2ZCf0";

  if (openLink && dialog && frame && typeof dialog.showModal === "function") {
    // Unmount the iframe to stop playback. Done explicitly in every close path
    // rather than relying on the dialog "close" event (not dispatched everywhere).
    const clear = () => {
      frame.innerHTML = "";
    };
    const closeTheater = () => {
      clear();
      if (dialog.open) dialog.close();
    };
    openLink.addEventListener("click", (e) => {
      e.preventDefault();
      frame.innerHTML = `<iframe src="https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0" title="Sheep Tag 2 trailer" allow="autoplay; encrypted-media; fullscreen; picture-in-picture" allowfullscreen></iframe>`;
      dialog.showModal();
    });
    closeBtn?.addEventListener("click", closeTheater);
    // Backdrop click closes (clicks that land on the dialog element itself).
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) closeTheater();
    });
    dialog.addEventListener("cancel", clear); // Esc key
    dialog.addEventListener("close", clear); // backup for browsers that fire it
  }
</script>
