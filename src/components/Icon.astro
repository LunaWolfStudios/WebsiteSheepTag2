---
import { ICONS } from "../lib/icons";

interface Props {
  name: string;
  size?: number;
  label?: string;
  class?: string;
}

const { name, size = 24, label, class: cls } = Astro.props;
const def = ICONS[name];
if (!def) throw new Error(`Icon "${name}" is not defined in src/lib/icons.ts`);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox={def.viewBox ?? "0 0 24 24"}
  fill={def.stroke ? "none" : "currentColor"}
  stroke={def.stroke ? "currentColor" : undefined}
  stroke-width={def.stroke ? 2 : undefined}
  stroke-linecap={def.stroke ? "round" : undefined}
  stroke-linejoin={def.stroke ? "round" : undefined}
  class={cls}
  role={label ? "img" : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : "true"}
  focusable="false"
>
  <path d={def.path}></path>
</svg>
