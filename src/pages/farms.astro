---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import farmsData from "../data/farms.json";
import type { ImageMetadata } from "astro";

interface Farm {
  name: string;
  slug: string;
  description: string;
  icon: string | null;
  variant: boolean;
}
const farms = farmsData as Farm[];

// Resolve farm icons (farms/Icon_*.png) to optimizable Astro images.
const iconModules = import.meta.glob<ImageMetadata>("../../farms/Icon_*.png", {
  eager: true,
  import: "default",
});
const iconByFile: Record<string, ImageMetadata> = {};
for (const [p, img] of Object.entries(iconModules)) {
  const file = p.split("/").pop();
  if (file) iconByFile[file] = img;
}

const base = farms.filter((f) => !f.variant);
const variants = farms.filter((f) => f.variant);

const groups = [
  { title: "Farms", intro: "Farms the Sheep build to wall off the Wolves.", items: base },
  {
    title: "Variants",
    intro: "Trick and hidden versions — Illusion farms your team can walk through, and invisible builds.",
    items: variants,
  },
];
---

<BaseLayout
  title="Farms — Sheep Tag 2"
  description="The farms of Sheep Tag 2 — from the humble Straw Farm to the Magic Farm — and what each one does."
>
  <section class="wrap farms">
    <header class="farms-head">
      <h1>Farms</h1>
      <p class="sub">
        Farms are how the Sheep survive. Build them to block paths, fortify, and outlast the Wolves.
      </p>
    </header>

    {
      groups.map((group) => (
        <section class="farm-group">
          <div class="group-head">
            <h2>{group.title}</h2>
            <p>{group.intro}</p>
          </div>
          <div class="farm-grid">
            {group.items.map((farm) => {
              const icon = farm.icon ? iconByFile[farm.icon] : undefined;
              return (
                <article class="farm-card">
                  <div class="farm-icon">
                    {icon && <Image src={icon} alt={`${farm.name} icon`} width={96} height={96} loading="lazy" />}
                  </div>
                  <div class="farm-body">
                    <h3>{farm.name}</h3>
                    <p set:html={farm.description} />
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      ))
    }
  </section>
</BaseLayout>

<style>
  .farms {
    padding-block: clamp(1.5rem, 4vw, 3rem) 4rem;
  }
  .farms-head h1 {
    font-size: clamp(2rem, 1.4rem + 2.5vw, 3rem);
  }
  .farms-head .sub {
    color: var(--st-ink-muted);
    margin-top: 0.3rem;
    max-width: 96ch; /* fits on one line on desktop; wraps naturally on narrow screens */
    text-wrap: pretty;
  }

  .farm-group {
    margin-top: clamp(2rem, 5vw, 3.5rem);
  }
  .group-head h2 {
    font-size: clamp(1.4rem, 1.1rem + 1.2vw, 1.9rem);
    color: var(--st-green-bright);
  }
  .group-head p {
    color: var(--st-ink-muted);
    margin-top: 0.2rem;
    margin-bottom: 1.25rem;
    max-width: 96ch;
    text-wrap: pretty;
  }

  .farm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  .farm-card {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 1rem;
    align-items: start;
    padding: 1rem;
    background: var(--st-surface);
    border: 1px solid var(--st-border);
    border-radius: var(--st-radius-lg);
    box-shadow: var(--st-shadow);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .farm-card:hover {
    border-color: color-mix(in srgb, var(--st-green) 55%, var(--st-border));
    transform: translateY(-2px);
  }
  .farm-icon {
    width: 88px;
    height: 88px;
    display: grid;
    place-items: center;
    background: radial-gradient(circle at 50% 40%, var(--st-bg-2), var(--st-surface));
    border: 1px solid var(--st-border);
    border-radius: 14px;
  }
  .farm-icon :global(img) {
    width: 72px;
    height: 72px;
    object-fit: contain;
    filter: drop-shadow(0 3px 8px rgba(0, 0, 0, 0.4));
  }
  .farm-body h3 {
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
  }
  .farm-body p {
    color: var(--st-ink-muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  @media (max-width: 460px) {
    .farm-card {
      grid-template-columns: 64px 1fr;
      gap: 0.8rem;
    }
    .farm-icon {
      width: 64px;
      height: 64px;
    }
    .farm-icon :global(img) {
      width: 52px;
      height: 52px;
    }
  }
</style>
